void setup() {
    Bridge.begin();
    pinMode(buzzerPin, OUTPUT);
    display.setI2CAddress(0x78);
    display.begin();
    display.setFont(u8g2_font_ncenB14_tr); 
}

void loop() {
    int potValue = analogRead(potPin);
    
    // Divide 1024 by 128 to get exactly 8 zones (0 through 7)
    int currentPart = potValue / 128;
    
    // Safety check just in case the math ever hits exactly 8
    if (currentPart > 7) { 
        currentPart = 7; 
    }

    // If the zone changed, update screen and beep
    if (currentPart != previousPart) {
        
        digitalWrite(buzzerPin, HIGH);
        delay(50);
        digitalWrite(buzzerPin, LOW);

        display.clearBuffer();  
        
        // Zone 0: Text "Pratik"
        if (currentPart == 0) {
            display.setCursor(30, 40); // Centered text
            display.print("Pratik");
        } 
        // Zone 1: Image Pratik
        else if (currentPart == 1) {
            display.drawBitmap(0, 0, 16, 64, imagePratik); 
        } 
        // Zone 2: Text "Yaraba"
        else if (currentPart == 2) {
            display.setCursor(30, 40);
            display.print("Yaraba");
        } 
        // Zone 3: Image Yaraba
        else if (currentPart == 3) {
            display.drawBitmap(0, 0, 16, 64, imageYaraba);
        } 
        // Zone 4: Text "Leima"
        else if (currentPart == 4) {
            display.setCursor(35, 40);
            display.print("Leima");
        } 
        // Zone 5: Image Leima
        else if (currentPart == 5) {
            display.drawBitmap(0, 0, 16, 64, imageLeima);
        } 
        // Zone 6: Text "Priyo"
        else if (currentPart == 6) {
            display.setCursor(35, 40);
            display.print("Priyo");
        } 
        // Zone 7: Image Priyo
        else if (currentPart == 7) {
            display.drawBitmap(0, 0, 16, 64, imagePriyo);
        }

        // Push everything to the physical screen
        display.sendBuffer(); 

        // Update memory
        previousPart = currentPart;
    }

    delay(15);
}
